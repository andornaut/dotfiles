(defwidget temperature [orientation]
  (box
    :class "temperature widget"
    :halign "fill"
    :orientation orientation
    :space-evenly false
    (label
      :class "temperature__label label icon"
      :text ""
      :tooltip "CPU Temperature"
    )
    (box
      :halign "center"
      :space-evenly false
      {round(EWW_TEMPS.K10TEMP_TCCD1, 0)}
      "°C"
    )
  )
)
